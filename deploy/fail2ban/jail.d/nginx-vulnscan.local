[nginx-vulnscan]
enabled = true
filter = nginx-vulnscan
port = http,https
logpath = /var/log/nginx/access.log
          /var/log/nginx/access.log.1
          /var/log/nginx/scanner-drop.log
          /var/log/nginx/scanner-drop.log.1
backend = polling
maxretry = 1
findtime = 10m
bantime = -1
banaction = ufw
