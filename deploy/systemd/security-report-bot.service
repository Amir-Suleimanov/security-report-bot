[Unit]
Description=Security Report Telegram Bot
After=network-online.target fail2ban.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/security-report-bot
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/etc/default/security-report-bot
ExecStart=/opt/security-report-bot/.venv/bin/python -m app.main
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
